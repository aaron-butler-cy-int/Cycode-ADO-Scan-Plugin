{
    "manifestVersion": 1,
    "id": "CycodeSecurityScan-Interal",
    "version": "0.2.28",
    "name": "Cycode Security Scan-Internal",
    "description": "Run Cycode security scans (SAST, SCA, Secrets, IaC) and view results as a dedicated build results tab.",
    "publisher": "AaronButler-Cycode",
    "public": false,
    "repository": {
        "type": "git",
        "url": "https://github.com/aaron-butler-cy-int/Cycode-ADO-Scan-Plugin"
    },
    "content": {
        "details": {
            "path": "overview.md"
        }
    },
    "icons": {
        "default": "images/cycode-logo.png"
    },
    "tags": [
        "Security",
        "Cycode",
        "SAST",
        "SCA",
        "Secrets",
        "IaC",
        "Code analysis"
    ],
    "scopes": [
        "vso.build_execute"
    ],
    "categories": [
        "Azure Pipelines"
    ],
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "files": [
        {
            "path": "images",
            "addressable": true
        },
        {
            "path": "dist",
            "addressable": true,
            "packagePath": "scripts"
        },
        {
            "path": "index.html",
            "addressable": true
        },
        {
            "path": "cycodescan/task.json",
            "packagePath": "cycodescan/task.json"
        },
        {
            "path": "cycodescan/ncc_out",
            "packagePath": "cycodescan/ncc_out"
        },
        {
            "path": "cycodeapigate/task.json",
            "packagePath": "cycodeapigate/task.json"
        },
        {
            "path": "cycodeapigate/ncc_out",
            "packagePath": "cycodeapigate/ncc_out"
        }
    ],
    "contributions": [
        {
            "id": "build-info-tab",
            "type": "ms.vss-build-web.build-results-tab",
            "description": "Cycode security scan results tab in the build results view",
            "targets": [
                "ms.vss-build-web.build-results-view"
            ],
            "properties": {
                "name": "Cycode Security Scan",
                "uri": "index.html",
                "supportsTasks": [
                    "3f7b8c9d-1e2f-4a5b-9c8d-7e6f5a4b3c2d",
                    "4a8c9d0e-2f3a-5b6c-ad9e-8f7a6b5c4d3e"
                ]
            }
        },
        {
            "id": "cycodescan",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "cycodescan"
            }
        },
        {
            "id": "cycodeapigate",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "cycodeapigate"
            }
        }
    ]
}
